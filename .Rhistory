# فراخوانی کتابخانه‌های مورد نیاز
library(tidyverse)
library(readxl)
library(corrplot)
# --- فاز ۱: وارد کردن و تمیزکاری داده‌ها (Data Wrangling) ---
my_data <- read_excel("Dataset.xlsx")
colnames(my_data) <- c("Year", "Precipitation", "Temperature", "Population", "Water_Level")
# بررسی بصری داده‌های پرت (Outliers)
par(mfrow=c(1,2))
boxplot(my_data$Water_Level, main="Water Level Status", col="lightblue", ylab="Meters")
boxplot(my_data$Precipitation, main="Precipitation Status", col="lightgreen", ylab="mm")
boxplot(my_data$Population, main="Population Status", col="lightblue", ylab="person")
boxplot(my_data$Temperature, main="Temperature Status", col="lightgreen", ylab="c")
# --- فاز ۲: آمار توصیفی و مصورسازی (EDA) ---
print("--- Summary Statistics ---")
print(summary(my_data))
# محاسبه انحراف معیار
sd_values <- data.frame(
Variable = c("Precipitation", "Temperature", "Population", "Water_Level"),
SD = c(sd(my_data$Precipitation), sd(my_data$Temperature),
sd(my_data$Population), sd(my_data$Water_Level))
)
print(sd_values)
# رسم هیستوگرام‌ها
par(mfrow=c(1,2))
hist(my_data$Water_Level, col="skyblue", border="white", main="Distribution: Water Level")
hist(my_data$Precipitation, col="lightgreen", border="white", main="Distribution: Precipitation")
hist(my_data$Population, col="skyblue", border="white", main="Distribution: Population")
hist(my_data$Temperature, col="lightgreen", border="white", ylab="Distribution: Temperature")
# نمودار پراکنش (رابطه جمعیت و تراز آب)
# نکته: این نمودار در تب Plots جداگانه باز می‌شود
plot_scatter <- ggplot(my_data, aes(x = Population, y = Water_Level)) +
geom_point(aes(color = Temperature), size = 3, alpha = 0.8) +
geom_smooth(method = "lm", color = "red", se = TRUE) +
scale_color_gradient(low = "blue", high = "orange") +
labs(title = "Relationship: Population Growth vs. Water Level Decline",
x = "Total Population", y = "Water Level (m)", color = "Temp (C)") +
theme_minimal()
print(plot_scatter)
# ۱. رابطه بارش و تراز آب (با همان استایل حرفه‌ای خودت)
plot_precip <- ggplot(my_data, aes(x = Precipitation, y = Water_Level)) +
geom_point(color = "blue", size = 3, alpha = 0.6) +
geom_smooth(method = "lm", color = "darkblue", se = TRUE) +
labs(title = "Relationship: Precipitation vs. Water Level",
x = "Precipitation (mm)", y = "Water Level (m)") +
theme_minimal()
# ۲. رابطه دما و تراز آب
plot_temp <- ggplot(my_data, aes(x = Temperature, y = Water_Level)) +
geom_point(color = "darkorange", size = 3, alpha = 0.6) +
geom_smooth(method = "lm", color = "red", se = TRUE) +
labs(title = "Relationship: Temperature vs. Water Level",
x = "Temperature (C)", y = "Water Level (m)") +
theme_minimal()
# نمایش نمودارها
print(plot_precip)
print(plot_temp)
# --- فاز ۳: استنباط آماری (Statistical Inference) ---
# مقایسه ۲۰ سال اول با ۲۰ سال اخیر
early_years <- my_data %>% filter(Year <= 1999) %>% pull(Water_Level)
recent_years <- my_data %>% filter(Year >= 2005) %>% pull(Water_Level)
t_test_result <- t.test(early_years, recent_years)
print("--- T-Test Results ---")
print(t_test_result)
# --- فاز ۴: همبستگی و رگرسیون (Correlation & Regression) ---
# ۱. ماتریس همبستگی
cor_matrix <- cor(my_data[, 2:5])
print("--- Correlation Matrix ---")
print(cor_matrix)
# رسم نمودار همبستگی
par(mfrow=c(1,1)) # برگرداندن تنظیمات گرافیکی به حالت تک صفحه
corrplot(cor_matrix, method = "circle", type = "upper", tl.col = "black")
# ۲. رگرسیون خطی ساده (مدل پیش‌بینی)
regression_model <- lm(Water_Level ~ Population, data = my_data)
print("--- Regression Model Summary ---")
print(summary(regression_model))
# ۳. رسم نمودار نهایی رگرسیون
plot_regression <- ggplot(my_data, aes(x = Population, y = Water_Level)) +
geom_point(color = "darkblue", alpha = 0.6) +
geom_smooth(method = "lm", color = "red", fill = "pink") +
labs(title = "Final Regression Model: Population Impact",
subtitle = paste("R-squared:", round(summary(regression_model)$r.squared, 4)),
x = "Population", y = "Water Level (m)") +
theme_light()
print(plot_regression)
# ۱. برازش مدل رگرسیون چندگانه
# در اینجا تراز آب را بر اساس هر سه عامل پیش‌بینی می‌کنیم
multiple_model <- lm(Water_Level ~ Precipitation + Temperature + Population, data = my_data)
# ۲. تحلیل خروجی مدل
print("--- Multiple Regression Summary ---")
summary_info <- summary(multiple_model)
print(summary_info)
# ۳. تفسیر شاخص Adjusted R-squared
# این شاخص نشان می‌دهد که آیا اضافه کردن دما و بارش، مدل ما را قوی‌تر کرده است یا خیر
adj_r2 <- summary_info$adj.r.squared
print(paste("Adjusted R-squared:", round(adj_r2, 4)))
# ۴. بررسی بصری باقی‌مانده‌های مدل (Diagnostic Plots)
# این نمودارها برای تایید سلامت مدل رگرسیون هستند
par(mfrow=c(2,2))
plot(multiple_model)
# ۱. انتخاب مدل بهینه با استفاده از معیار AIC
# این تابع به صورت خودکار متغیرهای اضافی را حذف می‌کند تا به بهترین مدل برسد
optimal_model <- step(lm(Water_Level ~ Precipitation + Temperature + Population, data = my_data),
direction = "both")
print("--- Summary of Optimal Model ---")
summary(optimal_model)
# ۲. بررسی پیش‌فرض‌های رگرسیون (نمودارهای تشخیصی)
# این ۴ نمودار اصلی‌ترین بخش برای اثبات صحت مدل شما هستند
par(mfrow=c(2,2))
plot(optimal_model)
# ۳. محاسبه دستی VIF برای بررسی هم‌خطی (Multicollinearity)
# چون کتابخانه car نصب نشد، از این روش علمی برای محاسبه استفاده می‌کنیم:
variables <- c("Precipitation", "Temperature", "Population")
vif_manual <- sapply(variables, function(var) {
formula  <- as.formula(paste(var, "~ ."))
# ستون‌های مورد نظر را جدا می‌کنیم (بدون تراز آب و سال)
sub_data <- my_data[, c("Precipitation", "Temperature", "Population")]
r_squared <- summary(lm(formula, data = sub_data))$r.squared
1 / (1 - r_squared)
})
print("--- Variance Inflation Factors (Manual VIF) ---")
print(vif_manual)
# ۱. استاندارد کردن داده‌ها
# این کار واحدها را حذف کرده و همه متغیرها را هم‌مقیاس می‌کند
std_data <- as.data.frame(scale(my_data[, c("Water_Level", "Precipitation", "Temperature", "Population")]))
# ۲. برازش مدل رگرسیون با داده‌های استاندارد شده
std_model <- lm(Water_Level ~ Precipitation + Temperature + Population, data = std_data)
# ۳. نمایش نتایج برای نتیجه‌گیری نهایی
print("--- Standardized Coefficients (Beta) ---")
print(summary(std_model)$coefficients)
# ۴. رسم یک نمودار میله‌ای ساده برای مقایسه سهم هر عامل در گزارش
library(ggplot2)
coef_df <- data.frame(
Variable = c("Precipitation", "Temperature", "Population"),
Coefficient = coef(std_model)[-1] # حذف ضریب عرض از مبدأ (Intercept)
)
ggplot(coef_df, aes(x = Variable, y = abs(Coefficient), fill = Variable)) +
geom_bar(stat = "identity") +
labs(title = "سهم هر عامل در تغییرات تراز آب (بر اساس ارزش مطلق ضرایب استاندارد)",
x = "عوامل", y = "قدرت تأثیر (Absolute Standardized Beta)") +
theme_minimal()
library(tidyverse)
library(readxl)
# Data Wrangling --------------------------------------------------------------
Dataset <- read_excel("Dataset.xlsx")
summary(Dataset)
#داده پرت
par(mfrow=c(2,2))
boxplot(Dataset$`تراز آب(m)`, main="تراز آب", col="lightblue", ylab="متر")
boxplot(Dataset$`بارش(mm)`, main="بارش", col="lightgreen", ylab="میلی‌متر")
boxplot(Dataset$`دما©`, main="دما", col="orange", ylab="سانتی‌گراد")
boxplot(Dataset$`جمعیت( ppl)`, main="جمعیت", col="pink", ylab="نفر")
par(mfrow=c(1,1))
#داده گمشده
colSums(is.na(Dataset))
#شاخص مرکزی
summary(Dataset)
#شاخص پراکندگی
sd(Dataset$`تراز آب(m)`)
sd(Dataset$`بارش(mm)`)
sd(Dataset$`دما©`)
sd(Dataset$`جمعیت( ppl)`)
#boxplot
par(mfrow=c(2,2))
boxplot(Dataset$`تراز آب(m)`, main="تراز آب", col="lightblue", ylab="متر")
boxplot(Dataset$`بارش(mm)`, main="بارش", col="lightgreen", ylab="میلی‌متر")
boxplot(Dataset$`دما©`, main="دما", col="orange", ylab="سانتی‌گراد")
boxplot(Dataset$`جمعیت( ppl)`, main="جمعیت", col="pink", ylab="نفر")
par(mfrow=c(1,1))
#histogram
par(mfrow=c(2,2))
hist(Dataset$`تراز آب(m)`, main="تراز آب", col="lightblue",xlab="متر")
hist(Dataset$`بارش(mm)`, main="بارش", col="lightgreen", xlab="میلی‌متر")
hist(Dataset$`دما©`, main="دما", col="orange", xlab="سانتی‌گراد")
hist(Dataset$`جمعیت( ppl)`, main="جمعیت", col="pink",xlab="نفر")
par(mfrow=c(1,1))
#scatterplot
par(mfrow=c(1,3))
plot(Dataset$`بارش(mm)`, Dataset$`تراز آب(m)`,
main="اثر بارش بر تراز آب",
xlab="بارش (میلی‌متر)", ylab="تراز آب (متر)",
col="blue")
abline(lm(Dataset$`تراز آب(m)`~ Dataset$`بارش(mm)`), col="red")
plot(Dataset$`دما©`,Dataset$`تراز آب(m)`,
main="اثر دما بر تراز آب",
xlab="دما (سانتی‌گراد)", ylab="تراز آب (متر)",
col="orange")
abline(lm(Dataset$`تراز آب(m)` ~ Dataset$`دما©`), col="red")
plot(Dataset$`جمعیت( ppl)`, Dataset$`تراز آب(m)`,
main="اثر جمعیت بر تراز آب",
xlab="جمعیت (نفر)", ylab="تراز آب (متر)",
col="green")
abline(lm(Dataset$`تراز آب(m)` ~ Dataset$`جمعیت( ppl)`), col="red")
par(mfrow=c(1,1))
# Inference ---------------------------------------------------------------
#confidence interval
con_int <- t.test(Dataset$`تراز آب(m)`, conf.level = 0.95)
con_int
con_int$conf.int
con_int$estimate
#hypothesis testing
Dataset$period <- ifelse(Dataset$Year <= 1999, "1980-1999", "2000-2024")
table(Dataset$period)
t_period <- t.test(`تراز آب(m)` ~ period, data = Dataset, conf.level = 0.95)
t_period
# Simple Regression -------------------------------------------------------
#correlation matrix
data_cor <- Dataset[, c("تراز آب(m)", "بارش(mm)", "دما©", "جمعیت( ppl)")]
cor_matrix <- cor(data_cor)
cor_matrix
#simple linear regression
simple_model <- lm(`تراز آب(m)` ~ `جمعیت( ppl)`, data = Dataset)
summary(simple_model)
plot(Dataset$`جمعیت( ppl)`, Dataset$`تراز آب(m)`,
main="اثر: جمعیت بر تراز آب",
xlab="جمعیت (نفر)", ylab="تراز آب (متر)",
col="darkblue")
abline(simple_model, col="red")
# multiple regression ------------------------------------------------------
multiple_model <- lm(`تراز آب(m)` ~ `بارش(mm)` + `دما©` + `جمعیت( ppl)`, data = Dataset)
summary(multiple_model)
#تحلیل نهایی و نتیجه گیری
Dataset_std <- Dataset
Dataset_std$`تراز آب(m)` <- as.numeric(scale(Dataset$`تراز آب(m)`))
Dataset_std$`بارش(mm)` <- as.numeric(scale(Dataset$`بارش(mm)`))
Dataset_std$`دما©` <- as.numeric(scale(Dataset$`دما©`))
Dataset_std$`جمعیت( ppl)` <- as.numeric(scale(Dataset$`جمعیت( ppl)`))
std_model <- lm(`تراز آب(m)` ~ `جمعیت( ppl)` + `بارش(mm)` + `دما©`, data = Dataset_std)
summary(std_model)
beta_std <- coef(std_model)[-1]
share <- abs(beta_std) / sum(abs(beta_std)) * 100
round(share, 2)
# multiple regression ------------------------------------------------------
multiple_model <- lm(`تراز آب(m)` ~ `بارش(mm)` + `دما©` + `جمعیت( ppl)`, data = Dataset)
summary(multiple_model)
