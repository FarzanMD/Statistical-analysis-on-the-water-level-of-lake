early_years <- my_data %>% filter(Year <= 1999) %>% pull(Water_Level)
recent_years <- my_data %>% filter(Year >= 2005) %>% pull(Water_Level)
t_test_result <- t.test(early_years, recent_years)
print("--- T-Test Results ---")
# فراخوانی کتابخانه‌های مورد نیاز
library(tidyverse)
library(readxl)
library(corrplot)
# --- فاز ۱: وارد کردن و تمیزکاری داده‌ها (Data Wrangling) ---
my_data <- read_excel("Dataset.xlsx")
colnames(my_data) <- c("Year", "Precipitation", "Temperature", "Population", "Water_Level")
# بررسی بصری داده‌های پرت (Outliers)
par(mfrow=c(1,2))
boxplot(my_data$Water_Level, main="Water Level Status", col="lightblue", ylab="Meters")
boxplot(my_data$Precipitation, main="Precipitation Status", col="lightgreen", ylab="mm")
boxplot(my_data$Population, main="Population Status", col="lightblue", ylab="person")
boxplot(my_data$Temperature, main="Temperature Status", col="lightgreen", ylab="c")
# --- فاز ۲: آمار توصیفی و مصورسازی (EDA) ---
print("--- Summary Statistics ---")
print(summary(my_data))
# محاسبه انحراف معیار
sd_values <- data.frame(
Variable = c("Precipitation", "Temperature", "Population", "Water_Level"),
SD = c(sd(my_data$Precipitation), sd(my_data$Temperature),
sd(my_data$Population), sd(my_data$Water_Level))
)
print(sd_values)
# رسم هیستوگرام‌ها
par(mfrow=c(1,2))
hist(my_data$Water_Level, col="skyblue", border="white", main="Distribution: Water Level")
hist(my_data$Precipitation, col="lightgreen", border="white", main="Distribution: Precipitation")
hist(my_data$Population, col="skyblue", border="white", main="Distribution: Population")
hist(my_data$Temperature, col="lightgreen", border="white", ylab="Distribution: Temperature")
# نمودار پراکنش (رابطه جمعیت و تراز آب)
# نکته: این نمودار در تب Plots جداگانه باز می‌شود
plot_scatter <- ggplot(my_data, aes(x = Population, y = Water_Level)) +
geom_point(aes(color = Temperature), size = 3, alpha = 0.8) +
geom_smooth(method = "lm", color = "red", se = TRUE) +
scale_color_gradient(low = "blue", high = "orange") +
labs(title = "Relationship: Population Growth vs. Water Level Decline",
x = "Total Population", y = "Water Level (m)", color = "Temp (C)") +
theme_minimal()
print(plot_scatter)
# ۱. رابطه بارش و تراز آب (با همان استایل حرفه‌ای خودت)
plot_precip <- ggplot(my_data, aes(x = Precipitation, y = Water_Level)) +
geom_point(color = "blue", size = 3, alpha = 0.6) +
geom_smooth(method = "lm", color = "darkblue", se = TRUE) +
labs(title = "Relationship: Precipitation vs. Water Level",
x = "Precipitation (mm)", y = "Water Level (m)") +
theme_minimal()
# ۲. رابطه دما و تراز آب
plot_temp <- ggplot(my_data, aes(x = Temperature, y = Water_Level)) +
geom_point(color = "darkorange", size = 3, alpha = 0.6) +
geom_smooth(method = "lm", color = "red", se = TRUE) +
labs(title = "Relationship: Temperature vs. Water Level",
x = "Temperature (C)", y = "Water Level (m)") +
theme_minimal()
# نمایش نمودارها
print(plot_precip)
print(plot_temp)
# --- فاز ۳: استنباط آماری (Statistical Inference) ---
# مقایسه ۲۰ سال اول با ۲۰ سال اخیر
early_years <- my_data %>% filter(Year <= 1999) %>% pull(Water_Level)
recent_years <- my_data %>% filter(Year >= 2005) %>% pull(Water_Level)
t_test_result <- t.test(early_years, recent_years)
print("--- T-Test Results ---")
print(t_test_result)
# --- فاز ۴: همبستگی و رگرسیون (Correlation & Regression) ---
# ۱. ماتریس همبستگی
cor_matrix <- cor(my_data[, 2:5])
print("--- Correlation Matrix ---")
print(cor_matrix)
# رسم نمودار همبستگی
par(mfrow=c(1,1)) # برگرداندن تنظیمات گرافیکی به حالت تک صفحه
corrplot(cor_matrix, method = "circle", type = "upper", tl.col = "black")
