#boxplot
par(mfrow=c(2,2))
boxplot(Dataset$`تراز آب(m)`, main="تراز آب", col="lightblue", ylab="متر")
boxplot(Dataset$`بارش(mm)`, main="بارش", col="lightgreen", ylab="میلی‌متر")
boxplot(Dataset$`دما©`, main="دما", col="orange", ylab="سانتی‌گراد")
boxplot(Dataset$`جمعیت( ppl)`, main="جمعیت", col="pink", ylab="نفر")
par(mfrow=c(1,1))
#histogram
par(mfrow=c(2,2))
hist(Dataset$`تراز آب(m)`, main="تراز آب", col="lightblue",xlab="متر")
hist(Dataset$`بارش(mm)`, main="بارش", col="lightgreen", xlab="میلی‌متر")
hist(Dataset$`دما©`, main="دما", col="orange", xlab="سانتی‌گراد")
hist(Dataset$`جمعیت( ppl)`, main="جمعیت", col="pink",xlab="نفر")
par(mfrow=c(1,1))
#scatterplot
par(mfrow=c(1,3))
plot(Dataset$`بارش(mm)`, Dataset$`تراز آب(m)`,
main="اثر بارش بر تراز آب",
xlab="بارش (میلی‌متر)", ylab="تراز آب (متر)",
col="blue")
abline(lm(Dataset$`تراز آب(m)`~ Dataset$`بارش(mm)`), col="red")
plot(Dataset$`دما©`,Dataset$`تراز آب(m)`,
main="اثر دما بر تراز آب",
xlab="دما (سانتی‌گراد)", ylab="تراز آب (متر)",
col="orange")
abline(lm(Dataset$`تراز آب(m)` ~ Dataset$`دما©`), col="red")
plot(Dataset$`جمعیت( ppl)`, Dataset$`تراز آب(m)`,
main="اثر جمعیت بر تراز آب",
xlab="جمعیت (نفر)", ylab="تراز آب (متر)",
col="green")
abline(lm(Dataset$`تراز آب(m)` ~ Dataset$`جمعیت( ppl)`), col="red")
par(mfrow=c(1,1))
# Inference ---------------------------------------------------------------
#confidence interval
con_int <- t.test(Dataset$`تراز آب(m)`, conf.level = 0.95)
con_int
con_int$conf.int
con_int$estimate
#hypothesis testing
Dataset$period <- ifelse(Dataset$Year <= 1999, "1980-1999", "2000-2024")
table(Dataset$period)
t_period <- t.test(`تراز آب(m)` ~ period, data = Dataset, conf.level = 0.95)
library(tidyverse)
library(readxl)
# Data Wrangling --------------------------------------------------------------
Dataset <- read_excel("Dataset.xlsx")
summary(Dataset)
#داده پرت
par(mfrow=c(2,2))
boxplot(Dataset$`تراز آب(m)`, main="تراز آب", col="lightblue", ylab="متر")
boxplot(Dataset$`بارش(mm)`, main="بارش", col="lightgreen", ylab="میلی‌متر")
boxplot(Dataset$`دما©`, main="دما", col="orange", ylab="سانتی‌گراد")
boxplot(Dataset$`جمعیت( ppl)`, main="جمعیت", col="pink", ylab="نفر")
par(mfrow=c(1,1))
#داده گمشده
colSums(is.na(Dataset))
#شاخص مرکزی
summary(Dataset)
